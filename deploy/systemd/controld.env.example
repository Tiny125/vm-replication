# /etc/vm-repl/controld.env — control plane configuration (read by systemd).
# Copy to /etc/vm-repl/controld.env and edit.

# HTTP listen address for the API, dashboard, and /metrics.
LISTEN=:8088

# Bearer token required on all API and metrics requests. Generate a strong one:
#   openssl rand -hex 32
CONTROL_TOKEN=change-me
