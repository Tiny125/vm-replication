# /etc/vm-repl/receiver.env — target receiver configuration (read by systemd).
# Copy to /etc/vm-repl/receiver.env and edit.

# Listen address (port the agent connects to).
LISTEN=:4444

# Target raw disk to apply blocks to (on a Linode staging instance this is the
# raw disk, e.g. /dev/sda in Rescue Mode).
DEVICE=/dev/sda

# Directory holding receiver.crt, receiver.key, ca.crt.
CERT_DIR=/etc/vm-repl
