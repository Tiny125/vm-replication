# /etc/vm-repl/agent.env — source agent configuration (read by systemd).
# Copy to /etc/vm-repl/agent.env and edit. EXTRA_ARGS is appended verbatim.

# Source disk to replicate (the whole device, not a partition).
DEVICE=/dev/sda

# Target receiver address and the SAN on its certificate.
TARGET=203.0.113.10:4444
SERVER_NAME=203.0.113.10

# Directory holding agent.crt, agent.key, ca.crt.
CERT_DIR=/etc/vm-repl

# Inventory name for this source (shown in the dashboard).
SOURCE_NAME=web01

# Control plane (optional). Leave CONTROL_URL empty to disable reporting.
CONTROL_URL=http://203.0.113.20:8088
CONTROL_TOKEN=change-me
CONTROL_JOB=1

# Extra agent flags, e.g. consistency or CBT backend:
#   --snapshot=lvm --lvm-snapshot-size 10G --pre-hook 'mysql -e "FLUSH TABLES WITH READ LOCK"'
#   --cbt=dmera --dmera-name vmrepl-data --dmera-meta /dev/vg/era_meta
#   --block-size 1048576
EXTRA_ARGS=
